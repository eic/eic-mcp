#!/usr/bin/env bash
#
# eic-mcp — run the EIC MCP servers as local HTTP services for an LLM client
#           (opencode, Copilot, Cursor, …). Hybrid: a server that is already
#           installed in the image (/opt/local/bin) is used as-is; one that
#           is not is bootstrapped automatically on first `up` (a one-time
#           clone + build). Same commands either way.
#
# Run it INSIDE eic-shell (Python, Node, git already present), or from the
# host: it finds your eic_xl .sif automatically (or set EIC_MCP_SIF).
#
#   eic-mcp list              # show the server registry
#   eic-mcp up                # start them (http://127.0.0.1:910x/mcp)
#   eic-mcp status            # which are listening
#   eic-mcp config CLIENT     # print client config (opencode|claude|copilot|vscode|cursor|gemini|codex)
#   eic-mcp logs NAME         # tail a server log
#   eic-mcp down | restart
#   eic-mcp setup             # optional pre-build ('up' does this automatically)
#
# Pick which servers to run (default: uproot xrootd rucio):
#   EIC_MCP_SERVERS="uproot xrootd rucio zenodo" eic-mcp up
#
# Add your own / future EIC servers WITHOUT editing this file — drop a file in
#   ~/.config/eic-mcp/servers.d/<name>.conf
# that calls `register …` (see the built-ins below for the signature).
#
set -euo pipefail

# Needs bash 4+ (associative arrays); macOS ships 3.2, the container has bash 5.
if [ "${BASH_VERSINFO:-0}" -lt 4 ]; then
  echo "eic-mcp needs bash 4+ (macOS ships 3.2) — run it inside eic-shell: ./eic-shell, then eic-mcp up" >&2
  exit 1
fi

# ---- config -----------------------------------------------------------------
# State (servers, logs, pidfiles) lives in ~/.eic-mcp — but in the Docker eic_xl image (macOS
# eic-shell) $HOME=/root is wiped on exit, so anchor it to EIC_SHELL_PREFIX (on the host).
if [ -z "${EIC_MCP_STATE:-}" ] && [ "$HOME" = "/root" ] && [ -n "${EIC_SHELL_PREFIX:-}" ] \
   && [ -z "${APPTAINER_CONTAINER:-}${SINGULARITY_CONTAINER:-}" ]; then
  EIC_MCP_STATE="$(dirname "$EIC_SHELL_PREFIX")/.eic-mcp"
fi
EIC_MCP_STATE="${EIC_MCP_STATE:-$HOME/.eic-mcp}"
EIC_MCP_DIR="${EIC_MCP_DIR:-$EIC_MCP_STATE/servers}"   # bootstrap checkouts
RUN_DIR="$EIC_MCP_STATE/run"; LOG_DIR="$EIC_MCP_STATE/logs"
BIND_HOST="${EIC_MCP_HOST:-127.0.0.1}"
EIC_MCP_SIF="${EIC_MCP_SIF:-}"
RUCIO_CFG="${RUCIO_CFG:-/opt/rucio/etc/rucio.cfg}"
CONF_DIR="${EIC_MCP_CONF_DIR:-$HOME/.config/eic-mcp/servers.d}"
NPM_CACHE="export npm_config_cache='$EIC_MCP_STATE/npm'"   # persists with the state

# ---- server registry --------------------------------------------------------
# register NAME PORT COMMAND REPO KIND [ENV_HOOK]
#   COMMAND  = the installed stdio MCP server command (preferred when on PATH,
#              i.e. /opt/local/bin/<cmd>). Exposed over streamable HTTP via supergateway.
#   REPO     = upstream git URL used to bootstrap when COMMAND is not installed
#   KIND     = py | node  (bootstrap build recipe; runtime is always stdio→streamable HTTP)
#   ENV_HOOK = a function name that echoes `export …` lines (auth/config)
declare -A SRV_PORT SRV_CMD SRV_REPO SRV_KIND SRV_ENV
SRV_ORDER=()
register() {
  local n=$1
  SRV_PORT[$n]=$2; SRV_CMD[$n]=$3; SRV_REPO[$n]=$4
  SRV_KIND[$n]=$5; SRV_ENV[$n]=${6:-}
  case " ${SRV_ORDER[*]:-} " in *" $n "*) :;; *) SRV_ORDER+=("$n");; esac
}

# --- per-server env hooks (echo shell `export` lines) ---
# Rucio: reuse the same shared read-only eicread account the CLI uses, straight
# from the container rucio.cfg. No user secrets.
rucio_env() {
  cat <<PY
eval "\$(python3 - <<'EOF'
import configparser, shlex
c = configparser.ConfigParser(); c.read("$RUCIO_CFG")
g = lambda k, d="": c.get("client", k, fallback=d)
print("export RUCIO_URL="       + shlex.quote(g("rucio_host", "https://rucio-server.jlab.org:443")))
print("export RUCIO_AUTH_TYPE=userpass")
print("export RUCIO_USERNAME="  + shlex.quote(g("username", "eicread")))
print("export RUCIO_PASSWORD="  + shlex.quote(g("password", "eicread")))
print("export RUCIO_ACCOUNT="   + shlex.quote(g("account",  g("username", "eicread"))))
print("export RUCIO_VO=")
EOF
)"
PY
}
# BNL disk serves current campaigns (25.12.0+); the JLab store stops at 25.10.x.
# For older data: XROOTD_SERVER=root://dtn-eic.jlab.org XROOTD_BASE_DIR=/volatile/eic/EPIC
xrootd_env() { echo "export XROOTD_SERVER='${XROOTD_SERVER:-root://epicxrd1.sdcc.bnl.gov:1095}' XROOTD_BASE_DIR='${XROOTD_BASE_DIR:-/eic/EPIC}'"; }
zenodo_env() { [ -n "${ZENODO_API_KEY:-}" ] && echo "export ZENODO_API_KEY='$ZENODO_API_KEY'" || echo ":"; }

# --- built-in EIC servers ---
register uproot 9101 uproot-mcp-server https://github.com/eic/uproot-mcp-server    py
register xrootd 9102 xrootd-mcp-server https://github.com/eic/xrootd-mcp-server    node xrootd_env
register rucio  9103 rucio-eic-mcp     https://github.com/eic/rucio-eic-mcp-server py   rucio_env
register zenodo 9104 zenodo-mcp-server https://github.com/eic/zenodo-mcp-server    node zenodo_env
# future: register indico 9105 indico-mcp-server https://github.com/cohm/indico-mcp node indico_env

# --- load user / collaboration extensions ---
# shellcheck disable=SC1090  # user drop-ins are dynamic by design
if [ -d "$CONF_DIR" ]; then for f in "$CONF_DIR"/*.conf; do [ -e "$f" ] && source "$f"; done; fi

enabled_servers() { echo "${EIC_MCP_SERVERS:-uproot xrootd rucio}"; }
srv_dir() { echo "$EIC_MCP_DIR/$(basename "${SRV_REPO[$1]}" .git)"; }

# ---- run inside the EIC software stack --------------------------------------
# apptainer markers, or /etc/eic-env.sh for the Docker eic_xl image (macOS)
in_container() { [ -n "${APPTAINER_CONTAINER:-}" ] || [ -n "${SINGULARITY_CONTAINER:-}" ] || [ -e /.singularity.d ] || [ -e /singularity ] || [ -e /etc/eic-env.sh ]; }
# Locate the eic_xl image the same way an eic-shell install lays it out:
# EIC_MCP_SIF (remembered), the last hit (cached), EIC_SHELL_PREFIX, the
# PREFIX= recorded in an eic-shell launcher (./eic-shell or on PATH), then
# $PWD and the quickstart default ~/eic. Any eic_xl-*.sif version counts.
find_sif() {
  local cache="$EIC_MCP_STATE/sif" d s launcher
  if [ -n "$EIC_MCP_SIF" ]; then
    mkdir -p "$EIC_MCP_STATE"; printf '%s\n' "$EIC_MCP_SIF" >"$cache"
    echo "$EIC_MCP_SIF"; return
  fi
  if [ -f "$cache" ]; then
    s="$(cat "$cache")"; [ -e "$s" ] && { echo "$s"; return; }
  fi
  local prefixes=()
  [ -n "${EIC_SHELL_PREFIX:-}" ] && prefixes+=("$EIC_SHELL_PREFIX" "${EIC_SHELL_PREFIX%/local}")
  for launcher in "$PWD/eic-shell" "$(command -v eic-shell 2>/dev/null || true)"; do
    [ -n "$launcher" ] && [ -f "$launcher" ] && \
      prefixes+=("$(sed -n '/^PREFIX=/{s/^PREFIX=//;s/^"//;s/"$//;p;q}' "$launcher")")
  done
  prefixes+=("$PWD" "$HOME/eic")
  for d in "${prefixes[@]}"; do
    [ -n "$d" ] || continue
    s="$(ls -1t "$d"/local/lib/eic_xl-*.sif "$d"/lib/eic_xl-*.sif 2>/dev/null | head -1)"
    [ -n "$s" ] && { mkdir -p "$EIC_MCP_STATE"; printf '%s\n' "$s" >"$cache"; echo "$s"; return; }
  done
  echo ""
}
# Run in the EIC environment the way eic-shell/entrypoint.sh do: source
# /etc/eic-env.sh explicitly, with --norc --noprofile so user/system dotfiles
# can't perturb it (matches the container's deliberate no-dotfiles behaviour).
ENV_PRELUDE='. /etc/eic-env.sh 2>/dev/null; '
sif_missing() { echo "ERROR: no eic_xl .sif found. macOS: eic-shell is Docker (no .sif) — run eic-mcp INSIDE ./eic-shell. Linux/WSL: run from your eic-shell install directory, or set EIC_MCP_SIF=/path/to/eic_xl-*.sif once (it is remembered)." >&2; }
run_in_env() {
  if in_container; then bash --norc --noprofile -c "$ENV_PRELUDE$1"; else
    local sif; sif="$(find_sif)"
    [ -z "$sif" ] && { sif_missing; exit 1; }
    apptainer exec "$sif" bash --norc --noprofile -c "$ENV_PRELUDE$1"
  fi
}
run_in_env_bg() {  # cmd pidfile logfile  — setsid → own process group for reliable stop
  local cmd="$1" pidfile="$2" logfile="$3" sif
  if in_container; then
    setsid bash --norc --noprofile -c "$ENV_PRELUDE$cmd" >"$logfile" 2>&1 </dev/null & echo $! >"$pidfile"
  else
    sif="$(find_sif)"; [ -z "$sif" ] && { sif_missing; return 1; }
    setsid apptainer exec "$sif" bash --norc --noprofile -c "$ENV_PRELUDE$cmd" >"$logfile" 2>&1 </dev/null & echo $! >"$pidfile"
  fi
}
# TCP connect test (SSE streams never close, so a curl GET would hang — not a failure).
port_open() { timeout 2 bash -c "exec 3<>/dev/tcp/$BIND_HOST/$1" 2>/dev/null; }
wait_ready() {  # name port timeout
  local name="$1" port="$2" timeout="${3:-60}" i pid
  pid="$(cat "$RUN_DIR/$name.pid" 2>/dev/null || true)"
  for ((i = 1; i <= timeout; i++)); do
    port_open "$port" && { echo "  ✓ $name ready on http://$BIND_HOST:$port/mcp"; return 0; }
    # fail fast if the process we launched already died (e.g. bind failed)
    if [[ "$pid" =~ ^[0-9]+$ ]] && ! kill -0 "$pid" 2>/dev/null; then
      echo "  ✗ $name exited before binding $port (see: eic-mcp logs $name)" >&2; return 1
    fi
    sleep 1
  done
  echo "  ✗ $name did NOT come up on port $port within ${timeout}s (eic-mcp logs $name)" >&2; return 1
}
# enabled servers that are actually in the registry (warn + skip unknown names)
resolved_servers() {
  local n
  for n in $(enabled_servers); do
    if [ -n "${SRV_PORT[$n]:-}" ]; then echo "$n"
    else echo "eic-mcp: unknown server '$n' (not in registry) — skipping" >&2; fi
  done
}

# ---- hybrid server resolution: installed → local build → bootstrap ----------
local_stdio() {  # the bootstrapped stdio command for server $1
  local n=$1 dir; dir="$(srv_dir "$n")"
  case "${SRV_KIND[$n]}" in
    py)   echo "$dir/.venv-eic/bin/${SRV_CMD[$n]}" ;;
    node) echo "node $dir/build/src/index.js" ;;
  esac
}
local_built() {  # host-visible check ($EIC_MCP_DIR lives under $EIC_MCP_STATE, visible on both sides)
  local n=$1 dir; dir="$(srv_dir "$n")"
  case "${SRV_KIND[$n]}" in
    py)   [ -x "$dir/.venv-eic/bin/${SRV_CMD[$n]}" ] ;;
    node) [ -e "$dir/build/src/index.js" ] ;;
  esac
}
cmd_installed() {  # probe inside the container env (PATH incl. /opt/local/bin)
  run_in_env "command -v '${SRV_CMD[$1]}' >/dev/null 2>&1"
}
bootstrap_server() {  # one-time clone + build of upstream main
  local n=$1 dir; dir="$(srv_dir "$n")"; mkdir -p "$EIC_MCP_DIR"
  [ -d "$dir/.git" ] || git clone --depth 1 "${SRV_REPO[$n]}" "$dir"
  case "${SRV_KIND[$n]}" in
    py)   run_in_env "cd '$dir' && { [ -d .venv-eic ] || python3 -m venv --system-site-packages .venv-eic; } && ./.venv-eic/bin/pip -q install ." ;;
    node) run_in_env "cd '$dir' && $NPM_CACHE && { [ -d node_modules ] || npm install; } && npm run build" ;;
  esac
}
ensure_server() {  # make server $1 runnable; no-op once installed or bootstrapped
  local n=$1
  local_built "$n" && return 0          # bootstrapped on an earlier run (cheap check first)
  cmd_installed "$n" && return 0        # shipped in this eic_xl image → nothing to do
  echo "==> $n: not shipped in this eic_xl image yet — bootstrapping once (clone + build, may take a few minutes)"
  bootstrap_server "$n"
}
prefetch_bridge() {  # make sure the stdio→HTTP bridge is runnable before wait_ready's clock starts
  run_in_env "command -v supergateway >/dev/null 2>&1 || { $NPM_CACHE; npx -y supergateway --version >/dev/null 2>&1 || true; }"
}

# ---- run recipe ---------------------------------------------------------------
# Every EIC server is a stdio MCP server; expose it over streamable HTTP with
# supergateway (stateful: one MCP session per client, so clients can reconnect —
# its SSE mode reuses a single session and crashes on the second connection).
# The bridge runs under a restart loop: supergateway also dies when a client
# disconnects mid tool call (the SDK throws on sending the late reply), and the
# loop turns that into a 1-second blip instead of a dead server. `eic-mcp down`
# still stops everything (the loop lives in the same setsid process group).
# Installed command and installed bridge are preferred; both fall back to the
# bootstrapped checkout / npx. Resolution happens at exec time INSIDE the
# container, so it never depends on the host PATH.
BRIDGE_ARGS="--outputTransport streamableHttp --stateful"
run_cmd() {  # echo the shell command that runs server $1 as an MCP-over-HTTP service
  local n=$1 port envfn env=""
  port=${SRV_PORT[$n]}; envfn=${SRV_ENV[$n]}
  [ -n "$envfn" ] && env="$($envfn) && "
  echo "${env}$NPM_CACHE && STDIO=\"\$(command -v '${SRV_CMD[$n]}' || echo \"$(local_stdio "$n")\")\" && while :; do if command -v supergateway >/dev/null 2>&1; then supergateway --stdio \"\$STDIO\" --port $port $BRIDGE_ARGS; else npx -y supergateway --stdio \"\$STDIO\" --port $port $BRIDGE_ARGS; fi; echo \"[eic-mcp] bridge exited (\$?) — restarting in 1s\" >&2; sleep 1; done"
}

# ---- commands ---------------------------------------------------------------
cmd_list() {
  printf "%-8s %-6s %-20s %-8s %s\n" NAME PORT COMMAND ENABLED REPO
  local en; en=" $(enabled_servers) "
  for n in "${SRV_ORDER[@]}"; do
    case "$en" in *" $n "*) e=yes;; *) e=no;; esac
    printf "%-8s %-6s %-20s %-8s %s\n" "$n" "${SRV_PORT[$n]}" "${SRV_CMD[$n]}" "$e" "${SRV_REPO[$n]}"
  done
}
# `setup` pre-builds everything so the first `up` is instant. Entirely optional:
# `up` runs the same steps automatically.
cmd_setup() {
  mkdir -p "$RUN_DIR" "$LOG_DIR"
  local n rc=0
  for n in $(resolved_servers); do
    if ensure_server "$n"; then echo "==> $n: ready"
    else echo "  ✗ $n: bootstrap failed" >&2; rc=1; fi
  done
  prefetch_bridge
  echo; echo "Setup complete (optional — 'eic-mcp up' does all of this automatically)."
  return $rc
}
cmd_up() {
  mkdir -p "$RUN_DIR" "$LOG_DIR"
  echo "Starting EIC MCP servers (streamable HTTP) ..."
  local n rc=0 opid; local -a launched=()
  for n in $(resolved_servers); do
    # already running under our control? (live pidfile PID + port up) → skip
    opid="$(cat "$RUN_DIR/$n.pid" 2>/dev/null || true)"
    if [[ "$opid" =~ ^[0-9]+$ ]] && kill -0 "$opid" 2>/dev/null && port_open "${SRV_PORT[$n]}"; then
      echo "  • $n already running (pid $opid) — skipping"; continue
    fi
    # port held by an unrelated process → don't clobber it, report failure
    if port_open "${SRV_PORT[$n]}"; then
      echo "  ⚠ $n: port ${SRV_PORT[$n]} already in use by another process — not starting" >&2; rc=1; continue
    fi
    if ! ensure_server "$n"; then echo "  ✗ $n: bootstrap failed — not starting" >&2; rc=1; continue; fi
    launched+=("$n")
  done
  [ ${#launched[@]} -gt 0 ] && prefetch_bridge
  for n in ${launched[@]+"${launched[@]}"}; do
    run_in_env_bg "$(run_cmd "$n")" "$RUN_DIR/$n.pid" "$LOG_DIR/$n.log"
  done
  [ ${#launched[@]} -gt 0 ] && echo "Waiting for servers ..."
  for n in ${launched[@]+"${launched[@]}"}; do wait_ready "$n" "${SRV_PORT[$n]}" 60 || rc=1; done
  echo
  [ "$rc" -eq 0 ] && echo "All servers up. Point your LLM client at them: eic-mcp config <client>" \
                  || echo "Some servers failed — check 'eic-mcp logs <name>'." >&2
  return $rc
}
stop_one() {
  local name="$1" pidfile="$RUN_DIR/$1.pid" port="${SRV_PORT[$1]:-}" pid i
  [ -z "$port" ] && { echo "  (unknown server $name)"; return; }
  if [ -f "$pidfile" ]; then
    pid="$(cat "$pidfile" 2>/dev/null || true)"
    if [[ "$pid" =~ ^[0-9]+$ ]]; then
      # kill the process group we started (setsid leader) — reliable and never
      # touches an unrelated process that merely happens to hold the port.
      kill -TERM -"$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true
      for ((i = 0; i < 6; i++)); do port_open "$port" || break; sleep 1; done
      if port_open "$port"; then kill -KILL -"$pid" 2>/dev/null || kill -KILL "$pid" 2>/dev/null || true; fi
    fi
    rm -f "$pidfile"
  fi
  if port_open "$port"; then
    echo "  ✗ $name: still listening on $port — could not stop (check 'eic-mcp logs $name' or kill it manually)" >&2
  else
    echo "  stopped $name"
  fi
}
cmd_down()   { echo "Stopping EIC MCP servers ..."; local n; for n in $(resolved_servers); do stop_one "$n"; done; }
cmd_status() {
  printf "%-8s %-30s %s\n" SERVER URL STATE
  local n; for n in $(resolved_servers); do
    port_open "${SRV_PORT[$n]}" && st=UP || st=down
    printf "%-8s %-30s %s\n" "$n" "http://$BIND_HOST:${SRV_PORT[$n]}/mcp" "$st"
  done
  echo "state: $EIC_MCP_STATE"
}
cmd_logs() {
  local n="${1:-}"; [ -z "$n" ] && { echo "usage: eic-mcp logs <name>" >&2; exit 2; }
  [ -n "${SRV_PORT[$n]:-}" ] || { echo "unknown server '$n' (see: eic-mcp list)" >&2; exit 2; }  # registered name only (no path traversal)
  exec tail -n 100 -f "$LOG_DIR/$n.log"
}
# `config CLIENT` prints an MCP client config pointing at the enabled servers'
# streamable-HTTP URLs. Redirect it to the client's config file:
#   opencode → opencode.jsonc (launch dir) or ~/.config/opencode/opencode.jsonc
#   claude   → .mcp.json              copilot → ~/.copilot/mcp-config.json  (CLI, *not* VS Code)
#   vscode   → .vscode/mcp.json       cursor  → .cursor/mcp.json
#   gemini   → .gemini/settings.json  codex   → append (>>) to ~/.codex/config.toml
cmd_config() {
  local client="${1:-opencode}" n url first=1
  case "$client" in
    opencode)
      echo '{'
      # shellcheck disable=SC2016  # literal "$schema" JSON key
      echo '  "$schema": "https://opencode.ai/config.json",'
      echo '  "mcp": {'
      for n in $(resolved_servers); do
        url="http://$BIND_HOST:${SRV_PORT[$n]}/mcp"
        [ $first -eq 1 ] || echo ','; first=0
        printf '    "%s": { "type": "remote", "url": "%s", "enabled": true }' "$n" "$url"
      done
      echo; echo '  }'; echo '}'
      ;;
    claude)   # Claude Code / Claude Desktop .mcp.json (project or ~/.claude.json)
      echo '{'; echo '  "mcpServers": {'
      for n in $(resolved_servers); do
        url="http://$BIND_HOST:${SRV_PORT[$n]}/mcp"
        [ $first -eq 1 ] || echo ','; first=0
        printf '    "%s": { "type": "http", "url": "%s" }' "$n" "$url"
      done
      echo; echo '  }'; echo '}'
      ;;
    copilot)  # GitHub Copilot CLI ~/.copilot/mcp-config.json (preinstalled in eic-shell)
      echo '{'; echo '  "mcpServers": {'
      for n in $(resolved_servers); do
        url="http://$BIND_HOST:${SRV_PORT[$n]}/mcp"
        [ $first -eq 1 ] || echo ','; first=0
        printf '    "%s": { "type": "http", "url": "%s", "tools": ["*"] }' "$n" "$url"
      done
      echo; echo '  }'; echo '}'
      ;;
    vscode)   # VS Code (Copilot Chat, Agent mode) .vscode/mcp.json
      echo '{'; echo '  "servers": {'
      for n in $(resolved_servers); do
        url="http://$BIND_HOST:${SRV_PORT[$n]}/mcp"
        [ $first -eq 1 ] || echo ','; first=0
        printf '    "%s": { "type": "http", "url": "%s" }' "$n" "$url"
      done
      echo; echo '  }'; echo '}'
      ;;
    cursor)   # Cursor .cursor/mcp.json (transport inferred from the URL)
      echo '{'; echo '  "mcpServers": {'
      for n in $(resolved_servers); do
        url="http://$BIND_HOST:${SRV_PORT[$n]}/mcp"
        [ $first -eq 1 ] || echo ','; first=0
        printf '    "%s": { "url": "%s" }' "$n" "$url"
      done
      echo; echo '  }'; echo '}'
      ;;
    gemini)   # Gemini CLI .gemini/settings.json (httpUrl = streamable HTTP; url would mean SSE)
      echo '{'; echo '  "mcpServers": {'
      for n in $(resolved_servers); do
        url="http://$BIND_HOST:${SRV_PORT[$n]}/mcp"
        [ $first -eq 1 ] || echo ','; first=0
        printf '    "%s": { "httpUrl": "%s" }' "$n" "$url"
      done
      echo; echo '  }'; echo '}'
      ;;
    codex)    # Codex CLI ~/.codex/config.toml (TOML — append with >>)
      for n in $(resolved_servers); do
        echo "[mcp_servers.$n]"
        echo "url = \"http://$BIND_HOST:${SRV_PORT[$n]}/mcp\""
      done
      ;;
    *) echo "unknown client '$client' (use: opencode | claude | copilot | vscode | cursor | gemini | codex)" >&2; exit 2 ;;
  esac
}

case "${1:-}" in
  list)    cmd_list ;;
  setup)   cmd_setup ;;
  up)      cmd_up ;;
  down)    cmd_down ;;
  restart) cmd_down; sleep 1; cmd_up ;;
  status)  cmd_status ;;
  logs)    shift; cmd_logs "${1:-}" ;;
  config)  shift; cmd_config "${1:-opencode}" ;;
  ""|-h|--help|help) sed -n '2,26p' "$0" | sed 's/^# \{0,1\}//' ;;
  *) echo "Unknown command: $1" >&2; echo "Try: eic-mcp help" >&2; exit 2 ;;
esac
